# Optional overrides for ./trellis and compose.yml.
#
# You usually do not need this file. The ./trellis launcher auto-detects:
# - TORCH_CUDA_ARCH_LIST from nvidia-smi, with GPU-name fallback
# - MAX_JOBS from CPU count, capped at 8
# - fallback host ports when the defaults are already in use
#
# Uncomment only the values you want to pin.

# TRELLIS_V1_PORT=8501
# TRELLIS_V2_PORT=7860
# TRELLIS_V2_TEXTURE_PORT=7861

# Examples for manual pinning, only if detection gets it wrong:
# RTX 3090 / A5000: 8.6
# RTX 4090: 8.9
# A100: 8.0
# H100: 9.0
# TORCH_CUDA_ARCH_LIST=8.9

# MAX_JOBS=8

# TRELLIS.2 attention backends. FlashAttention is the quality-first default.
# SageAttention remains available as an opt-in speed experiment.
# ATTN_BACKEND=flash_attn
# SPARSE_ATTN_BACKEND=flash_attn
# To try SageAttention:
# ATTN_BACKEND=sage
# SAGEATTENTION_PACKAGE=sageattention==1.0.6

# TRELLIS.2 uses the public timm conversion of DINOv3 ViT-L/16 by default to
# avoid the gated Meta checkpoint. Use meta-dinov3 for the original model.
# TRELLIS2_IMAGE_ENCODER=timm-dinov3
# TRELLIS2_DINOV3_MODEL=hf_hub:timm/vit_large_patch16_dinov3_qkvb.lvd1689m
# TRELLIS2_DINOV3_IMAGE_SIZE=512
# TRELLIS2_TIMM_DINOV3_TRUNCATE_ROPE=1
# TRELLIS2_DINOV3_TELEMETRY=0

# TRELLIS.2 background removal. Default is ungated: use existing alpha, otherwise
# the public full BiRefNet model. Bria remains opt-in.
# TRELLIS2_REMBG_BACKEND=auto
# TRELLIS2_REMBG_MODEL=ZhengPeng7/BiRefNet
# TRELLIS2_REMBG_REVISION=e2bf8e4460fc8fa32bba5ea4d94b3233d367b0e4
# TRELLIS2_REMBG_DEVICE=auto
# TRELLIS2_REMBG_DTYPE=float16
# Presets:
#   auto     existing alpha; otherwise ZhengPeng7/BiRefNet
#   birefnet ZhengPeng7/BiRefNet
#   lite     ZhengPeng7/BiRefNet_lite
#   bria     briaai/RMBG-2.0
#   none     require an alpha-masked RGBA image

# Usually auto-detected by ./trellis so mounted outputs/caches are writable.
# HOST_UID=1000
# HOST_GID=1000

# Optional Hugging Face token for gated/private models or higher rate limits.
# If this is unset, ./trellis tries ~/.cache/huggingface/token from
# `huggingface-cli login`.
# HF_TOKEN=

# TRELLIS.2 favors lower VRAM by default. Set to 0 for speed on larger GPUs.
# TRELLIS2_FLOW_BLOCK_OFFLOAD=1
