#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${ROOT_DIR}"

usage() {
    cat <<'EOF'
TRELLIS-BOX

Usage:
  ./trellis --version 1       Start original TRELLIS at http://localhost:8501
  ./trellis --version 2       Start TRELLIS.2 at http://localhost:7860
  ./trellis -v 2              Start TRELLIS.2 at http://localhost:7860
  ./trellis texture           Start TRELLIS.2 texturing at http://localhost:7861

Other commands:
  ./trellis dev --version 1   Start version 1 with source mounts
  ./trellis dev --version 2   Start version 2 with source mounts
  ./trellis build --version 2  Build one app without starting it
  ./trellis logs --version 2   Follow logs for one app
  ./trellis ps                Show containers
  ./trellis stop              Stop containers
  ./trellis config            Show detected config
  ./trellis check             Check host and Docker GPU access

Versions: 1, 2

The launcher auto-detects the common knobs: GPU architecture, build jobs, and
fallback ports. Put values in .env only when you want to override that behavior.
EOF
}

compose() {
    if docker compose version >/dev/null 2>&1; then
        docker compose "$@"
    elif command -v docker-compose >/dev/null 2>&1; then
        docker-compose "$@"
    else
        echo "Docker Compose is not installed." >&2
        exit 1
    fi
}

prepare_dirs() {
    : "${HOME:?HOME is not set}"
    mkdir -p \
        "${HOME}/.cache/huggingface" \
        "${HOME}/.cache/rembg" \
        "${HOME}/.cache/trellis/triton" \
        TRELLIS/outputs \
        TRELLIS.2/tmp \
        TRELLIS.2/outputs
}

VERSION=""
POSITIONAL=()
RESERVED_PORTS=()

parse_version_args() {
    VERSION=""
    POSITIONAL=()

    while [ "$#" -gt 0 ]; do
        case "$1" in
            -v|--version)
                shift
                if [ "$#" -eq 0 ]; then
                    echo "Missing value for --version." >&2
                    exit 1
                fi
                VERSION="$1"
                ;;
            --version=*)
                VERSION="${1#*=}"
                ;;
            *)
                POSITIONAL+=("$1")
                ;;
        esac
        shift
    done
}

env_file_has() {
    local key="$1"
    [ -f ".env" ] && grep -Eq "^[[:space:]]*${key}=" .env
}

env_file_value() {
    local key="$1"
    local line value

    [ -f ".env" ] || return 1
    line="$(grep -E "^[[:space:]]*${key}=" .env | tail -n 1 || true)"
    [ -n "${line}" ] || return 1
    value="${line#*=}"
    value="${value%%#*}"
    value="${value%\"}"
    value="${value#\"}"
    value="${value%\'}"
    value="${value#\'}"
    value="${value//[[:space:]]/}"
    [ -n "${value}" ] || return 1
    printf '%s\n' "${value}"
}

set_auto_default() {
    local key="$1"
    local value="$2"

    if [ -n "${!key:-}" ] || env_file_has "${key}"; then
        return
    fi

    export "${key}=${value}"
}

detect_cpu_count() {
    getconf _NPROCESSORS_ONLN 2>/dev/null || echo 8
}

detect_max_jobs() {
    local cpus jobs
    cpus="$(detect_cpu_count)"

    case "${cpus}" in
        ''|*[!0-9]*)
            jobs=8
            ;;
        *)
            jobs="${cpus}"
            ;;
    esac

    if [ "${jobs}" -gt 8 ]; then
        jobs=8
    elif [ "${jobs}" -lt 1 ]; then
        jobs=1
    fi

    echo "${jobs}"
}

detect_host_uid() {
    id -u 2>/dev/null || echo 1000
}

detect_host_gid() {
    id -g 2>/dev/null || echo 1000
}

read_token_file() {
    local token_file="$1"
    local token

    [ -f "${token_file}" ] || return 1
    IFS= read -r token < "${token_file}" || return 1
    token="$(first_hf_token "${token}")" || return 1
    printf '%s\n' "${token}"
}

first_hf_token() {
    grep -Eo 'hf_[A-Za-z0-9]{20,}' <<< "${1:-}" | head -n 1
}

detect_hf_token() {
    local token

    if [ -n "${HUGGING_FACE_HUB_TOKEN:-}" ]; then
        token="$(first_hf_token "${HUGGING_FACE_HUB_TOKEN}" || true)"
        if [ -n "${token}" ]; then
            printf '%s\n' "${token}"
            return 0
        fi
    fi

    token="$(env_file_value HF_TOKEN || true)"
    if [ -n "${token}" ]; then
        token="$(first_hf_token "${token}" || true)"
        if [ -n "${token}" ]; then
            printf '%s\n' "${token}"
            return 0
        fi
    fi

    if command -v hf >/dev/null 2>&1; then
        token="$(first_hf_token "$(hf auth token 2>/dev/null || true)" || true)"
        if [ -n "${token}" ]; then
            printf '%s\n' "${token}"
            return 0
        fi
    fi

    for token_file in \
        "${HF_TOKEN_FILE:-}" \
        "${HF_TOKEN_PATH:-}" \
        "${HF_HOME:-${HOME}/.cache/huggingface}/token" \
        "${XDG_CACHE_HOME:-${HOME}/.cache}/huggingface/token" \
        "${HOME}/.cache/huggingface/token" \
        "${HOME}/.huggingface/token"
    do
        [ -n "${token_file}" ] || continue
        token="$(read_token_file "${token_file}" || true)"
        if [ -n "${token}" ]; then
            printf '%s\n' "${token}"
            return 0
        fi
    done

    for token_file in \
        "${HF_HOME:-${HOME}/.cache/huggingface}/stored_tokens" \
        "${XDG_CACHE_HOME:-${HOME}/.cache}/huggingface/stored_tokens"
    do
        [ -f "${token_file}" ] || continue
        token="$(grep -Eo 'hf_[A-Za-z0-9]{20,}' "${token_file}" | head -n 1 || true)"
        if [ -n "${token}" ]; then
            printf '%s\n' "${token}"
            return 0
        fi
    done

    return 1
}

sage_supported_arch() {
    case "${1:-}" in
        8.0|8.6|8.9|9.0)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

detect_gpu_arch() {
    if ! command -v nvidia-smi >/dev/null 2>&1; then
        return 1
    fi

    nvidia-smi --query-gpu=compute_cap --format=csv,noheader 2>/dev/null \
        | head -n 1 \
        | tr -d '[:space:]'
}

port_is_open() {
    local port="$1"
    ! (:</dev/tcp/127.0.0.1/"${port}") >/dev/null 2>&1
}

port_is_reserved() {
    local port="$1"
    local reserved

    for reserved in "${RESERVED_PORTS[@]}"; do
        if [ "${reserved}" = "${port}" ]; then
            return 0
        fi
    done
    return 1
}

reserve_port() {
    local port="${1:-}"
    [ -n "${port}" ] || return
    RESERVED_PORTS+=("${port}")
}

next_open_port() {
    local port="$1"
    local limit=$((port + 50))

    while [ "${port}" -le "${limit}" ]; do
        if port_is_open "${port}" && ! port_is_reserved "${port}"; then
            echo "${port}"
            return 0
        fi
        port=$((port + 1))
    done

    return 1
}

set_auto_port() {
    local key="$1"
    local preferred="$2"
    local port configured_port

    if [ -n "${!key:-}" ]; then
        reserve_port "${!key}"
        return
    fi

    if env_file_has "${key}"; then
        configured_port="$(env_file_value "${key}" || true)"
        reserve_port "${configured_port}"
        return
    fi

    port="$(next_open_port "${preferred}")" || {
        export "${key}=${preferred}"
        return
    }

    export "${key}=${port}"
    reserve_port "${port}"
}

configure_auto_env() {
    local gpu_arch hf_token

    set_auto_default MAX_JOBS "$(detect_max_jobs)"
    set_auto_default HOST_UID "$(detect_host_uid)"
    set_auto_default HOST_GID "$(detect_host_gid)"
    set_auto_default TRELLIS2_FLOW_BLOCK_OFFLOAD 1
    set_auto_default TRELLIS2_IMAGE_ENCODER timm-dinov3

    if [ -z "${HF_TOKEN:-}" ]; then
        hf_token="$(detect_hf_token || true)"
        if [ -n "${hf_token}" ]; then
            export HF_TOKEN="${hf_token}"
        fi
    fi
    if [ -n "${HF_TOKEN:-}" ] && [ -z "${HUGGING_FACE_HUB_TOKEN:-}" ]; then
        export HUGGING_FACE_HUB_TOKEN="${HF_TOKEN}"
    fi

    if [ -z "${TORCH_CUDA_ARCH_LIST:-}" ] && ! env_file_has TORCH_CUDA_ARCH_LIST; then
        gpu_arch="$(detect_gpu_arch || true)"
        if [[ "${gpu_arch}" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
            export TORCH_CUDA_ARCH_LIST="${gpu_arch}"
        fi
    fi

    gpu_arch="${TORCH_CUDA_ARCH_LIST:-}"
    gpu_arch="${gpu_arch%% *}"
    if [ -z "${ATTN_BACKEND:-}" ] && ! env_file_has ATTN_BACKEND; then
        if sage_supported_arch "${gpu_arch}"; then
            export ATTN_BACKEND=sage
        else
            export ATTN_BACKEND=flash_attn
        fi
    fi
    set_auto_default SPARSE_ATTN_BACKEND flash_attn

    set_auto_port TRELLIS_V1_PORT 8501
    set_auto_port TRELLIS_V2_PORT 7860
    set_auto_port TRELLIS_V2_TEXTURE_PORT 7861
}

print_auto_env() {
    local parts=()

    if [ -n "${TORCH_CUDA_ARCH_LIST:-}" ]; then
        parts+=("GPU arch ${TORCH_CUDA_ARCH_LIST}")
    fi
    if [ -n "${MAX_JOBS:-}" ]; then
        parts+=("MAX_JOBS=${MAX_JOBS}")
    fi
    if [ -n "${HOST_UID:-}" ] && [ -n "${HOST_GID:-}" ]; then
        parts+=("UID:GID=${HOST_UID}:${HOST_GID}")
    fi
    if [ -n "${HF_TOKEN:-}" ]; then
        parts+=("HF token detected")
    else
        parts+=("HF token missing")
    fi
    if [ -n "${ATTN_BACKEND:-}" ]; then
        parts+=("dense attention=${ATTN_BACKEND}")
    fi
    if [ -n "${SPARSE_ATTN_BACKEND:-}" ]; then
        parts+=("sparse attention=${SPARSE_ATTN_BACKEND}")
    fi
    if [ -n "${TRELLIS2_IMAGE_ENCODER:-}" ]; then
        parts+=("image encoder=${TRELLIS2_IMAGE_ENCODER}")
    fi
    parts+=("ports 1:${TRELLIS_V1_PORT:-8501} 2:${TRELLIS_V2_PORT:-7860} texture:${TRELLIS_V2_TEXTURE_PORT:-7861}")

    printf 'Auto config: '
    local index=0
    for part in "${parts[@]}"; do
        if [ "${index}" -gt 0 ]; then
            printf ', '
        fi
        printf '%s' "${part}"
        index=$((index + 1))
    done
    printf '\n'
}

service_for_version() {
    case "${1:-}" in
        1)
            echo "v1"
            ;;
        2)
            echo "v2"
            ;;
        "")
            echo "Missing version. Use --version 1 or --version 2." >&2
            return 1
            ;;
        *)
            echo "Unknown version: ${1}. Use --version 1 or --version 2." >&2
            return 1
            ;;
    esac
}

image_for_service() {
    case "${1:-}" in
        v1)
            echo "trellis-box:v1"
            ;;
        v2|v2-texture)
            echo "trellis-box:v2"
            ;;
        *)
            return 1
            ;;
    esac
}

ensure_image_exists() {
    local service="$1"
    local image

    image="$(image_for_service "${service}")" || return 0
    if ! docker image inspect "${image}" >/dev/null 2>&1; then
        echo "Image ${image} is missing; building ${service} once."
        compose build "${service}"
    fi
}

run_services() {
    prepare_dirs
    configure_auto_env
    print_auto_env
    ensure_image_exists "$1"
    compose up "$@"
}

cmd="${1:-help}"
if [ "$#" -gt 0 ]; then
    shift
fi

case "${cmd}" in
    -v|--version|--version=*)
        parse_version_args "${cmd}" "$@"
        if [ "${#POSITIONAL[@]}" -gt 0 ]; then
            echo "Unexpected argument: ${POSITIONAL[0]}" >&2
            usage
            exit 1
        fi
        service="$(service_for_version "${VERSION}")" || {
            usage
            exit 1
        }
        run_services "${service}"
        ;;
    start|run)
        parse_version_args "$@"
        if [ "${#POSITIONAL[@]}" -gt 0 ]; then
            echo "Unexpected argument: ${POSITIONAL[0]}" >&2
            usage
            exit 1
        fi
        service="$(service_for_version "${VERSION}")" || {
            usage
            exit 1
        }
        run_services "${service}"
        ;;
    texture|texturing|v2-texture)
        prepare_dirs
        configure_auto_env
        print_auto_env
        ensure_image_exists v2-texture
        compose --profile extras up v2-texture
        ;;
    dev)
        parse_version_args "$@"
        if [ "${#POSITIONAL[@]}" -gt 0 ]; then
            echo "Unexpected argument for dev: ${POSITIONAL[0]}" >&2
            usage
            exit 1
        fi
        service="$(service_for_version "${VERSION}")" || {
            usage
            exit 1
        }
        prepare_dirs
        configure_auto_env
        print_auto_env
        ensure_image_exists "${service}"
        compose -f compose.yml -f compose.dev.yml up "${service}"
        ;;
    build)
        parse_version_args "$@"
        if [ "${#POSITIONAL[@]}" -gt 0 ]; then
            echo "Unexpected argument for build: ${POSITIONAL[0]}" >&2
            usage
            exit 1
        fi
        service="$(service_for_version "${VERSION}")" || {
            usage
            exit 1
        }
        prepare_dirs
        configure_auto_env
        print_auto_env
        compose build "${service}"
        ;;
    logs)
        parse_version_args "$@"
        if [ "${#POSITIONAL[@]}" -gt 0 ]; then
            echo "Unexpected argument for logs: ${POSITIONAL[0]}" >&2
            usage
            exit 1
        fi
        if [ -z "${VERSION}" ]; then
            compose logs -f
        else
            service="$(service_for_version "${VERSION}")" || {
                usage
                exit 1
            }
            compose logs -f "${service}"
        fi
        ;;
    ps|status)
        compose ps
        ;;
    config|env)
        prepare_dirs
        configure_auto_env
        print_auto_env
        ;;
    stop|down)
        compose down --remove-orphans
        ;;
    check)
        if command -v nvidia-smi >/dev/null 2>&1; then
            nvidia-smi
        else
            echo "Host nvidia-smi was not found."
        fi
        docker run --rm --gpus all nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04 nvidia-smi
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        echo "Unknown command: ${cmd}" >&2
        usage
        exit 1
        ;;
esac
